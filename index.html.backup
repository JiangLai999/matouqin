                        <div class="hero-subtitle">
                            <p>A digital archive mapping the cultural DNA, acoustic heritage, and traditional craftsmanship of the Mongolian horsehead fiddle through flowing parametric structures.</p>
                        </div>
                    </div>
                </div>
                
                <footer class="hero-footer">
                    <div class="hero-meta">
                        <span>Vol. I — <strong>内蒙古非物质文化遗产</strong></span>
                        <span>Coordinates: 40.8420° N, 111.7500° E (Hohhot)</span>
                    </div>
                    <div class="scroll-indicator">
                        <span class="scroll-text">Discover</span>
                        <div class="scroll-line"></div>
                    </div>
                </footer>
            </div>
        </section>

        <!-- Dashboard Section -->
        <section id="dashboard" class="dashboard-section">
            <div class="dashboard-grid">
                <div class="dashboard-card">
                    <span class="dash-number">2000</span>
                    <span class="dash-unit">年</span>
                    <span class="dash-label">历史传承</span>
                    <p class="dash-desc">起源于唐宋时期的拉弦乐器奚琴</p>
                </div>
                <div class="dashboard-card">
                    <span class="dash-number">100</span>
                    <span class="dash-unit">+</span>
                    <span class="dash-label">道制作工序</span>
                    <p class="dash-desc">琴头、琴杆、琴箱三大核心环节</p>
                </div>
                <div class="dashboard-card">
                    <span class="dash-number">2006</span>
                    <span class="dash-unit">年</span>
                    <span class="dash-label">国家级非遗</span>
                    <p class="dash-desc">首批列入国家级非物质文化遗产名录</p>
                </div>
                <div class="dashboard-card">
                    <span class="dash-number">4</span>
                    <span class="dash-unit">大</span>
                    <span class="dash-label">演奏流派</span>
